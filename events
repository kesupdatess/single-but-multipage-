body.dark .hamburger { background: rgba(30,41,59,0.9); color: white; border-color: rgba(99,102,241,0.2); }
body.dark footer { color: #94a3b8; }
body.dark .theme-toggle { background: rgba(30,41,59,0.9); border-color: rgba(99,102,241,0.2); }
body.dark .back-link { color: #60a5fa; }
body.dark .back-link:hover { color: #93c5fd; }
body.dark .event-item { background: rgba(30,41,59,0.9); border-color: rgba(99,102,241,0.15); }
body.dark .event-name { color: #93c5fd; }
body.dark .event-date { color: #94a3b8; }
body.dark .event-countdown { background: rgba(239,68,68,0.15); }
body.dark .event-countdown.soon { background: rgba(245,158,11,0.15); }
body.dark .event-countdown.far { background: rgba(16,185,129,0.15); }
body.dark .info-box { background: rgba(99,102,241,0.08); border-color: rgba(99,102,241,0.15); }
